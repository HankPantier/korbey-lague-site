# Resend API key for /api/contact email delivery.
# Get one at https://resend.com → API Keys.
# Leave blank in dev to use the built-in mailto: fallback.
RESEND_API_KEY=""

# Google Analytics 4 measurement ID (G-XXXXXXXXXX).
# Loaded via @next/third-parties after the visitor accepts the
# consent banner. Leave blank to disable GA4.
NEXT_PUBLIC_GA4_ID=""

# Google Tag Manager container ID (GTM-XXXXXX).
# If set, GTM is loaded instead of GA4 (GTM can load GA4 itself plus
# any other tags the client wires in). Leave blank to disable GTM.
NEXT_PUBLIC_GTM_ID=""
